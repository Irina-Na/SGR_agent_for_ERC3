name,sql
payment_transaction_items,"CREATE TABLE payment_transaction_items (
	payment_id TEXT NOT NULL,
	line_number INTEGER NOT NULL,
	product_sku TEXT NOT NULL,
	purchased_quantity INTEGER NOT NULL,
	item_unit_price_cents INTEGER NOT NULL,
	PRIMARY KEY (payment_id, line_number),
	FOREIGN KEY (payment_id) REFERENCES payment_transactions(payment_id),
	FOREIGN KEY (product_sku) REFERENCES product_variants(product_sku)
)"
payment_transaction_items_sku_idx,CREATE INDEX payment_transaction_items_sku_idx ON payment_transaction_items(product_sku)
payment_transactions,"CREATE TABLE payment_transactions (
	payment_id TEXT PRIMARY KEY,
	record_path TEXT NOT NULL,
	basket_id TEXT NOT NULL,
	is_archived_basket_reference INTEGER NOT NULL,
	customer_id TEXT NOT NULL,
	store_id TEXT NOT NULL,
	payment_amount_cents INTEGER NOT NULL,
	payment_currency TEXT NOT NULL,
	payment_status TEXT NOT NULL,
	payment_created_at TEXT NOT NULL,
	payment_method_fingerprint TEXT NOT NULL,
	device_fingerprint TEXT NOT NULL,
	observed_latitude REAL NOT NULL,
	observed_longitude REAL NOT NULL,
	three_ds_status TEXT,
	three_ds_failure_reason TEXT,
	three_ds_attempts INTEGER,
	three_ds_max_attempts INTEGER,
	FOREIGN KEY (customer_id) REFERENCES customer_accounts(customer_id),
	FOREIGN KEY (store_id) REFERENCES stores(store_id)
)"
payment_transactions_basket_idx,CREATE INDEX payment_transactions_basket_idx ON payment_transactions(basket_id)
payment_transactions_created_at_idx,CREATE INDEX payment_transactions_created_at_idx ON payment_transactions(payment_created_at)
payment_transactions_customer_idx,CREATE INDEX payment_transactions_customer_idx ON payment_transactions(customer_id)
payment_transactions_device_fingerprint_idx,CREATE INDEX payment_transactions_device_fingerprint_idx ON payment_transactions(device_fingerprint)
payment_transactions_method_fingerprint_idx,CREATE INDEX payment_transactions_method_fingerprint_idx ON payment_transactions(payment_method_fingerprint)
payment_transactions_status_idx,CREATE INDEX payment_transactions_status_idx ON payment_transactions(payment_status)
payment_transactions_store_idx,CREATE INDEX payment_transactions_store_idx ON payment_transactions(store_id)
return_requests_payment_idx,CREATE INDEX return_requests_payment_idx ON return_requests(payment_id)
