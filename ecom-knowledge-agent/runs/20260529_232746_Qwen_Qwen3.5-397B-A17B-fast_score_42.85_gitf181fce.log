	payment_amount_cents INTEGER NOT NULL,
	payment_currency TEXT NOT NULL,
	payment_status TEXT NOT NULL,
	payment_created_at TEXT NOT NULL,
	payment_method_fingerprint TEXT NOT NULL,
	device_fingerprint TEXT NOT NULL,
