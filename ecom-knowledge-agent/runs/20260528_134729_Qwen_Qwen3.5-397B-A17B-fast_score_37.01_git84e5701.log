  tool='exec' path='/bin/sql' args=[] stdin="WITH matching_products AS (\n  SELECT \n    p.sku,\n    p.brand,\n    f.series,\n    f.model,\n    CASE \n      WHEN p.brand = 'Legrand' AND f.series LIKE '%Plexo%' AND f.model LIKE '%2XT-4EJ%' THEN 1\n      WHEN p.brand = 'Stanley' AND f.series LIKE '%Professional%' AND f.model LIKE '%STA 1IB-RUE%' THEN 2\n      WHEN p.brand = 'Engelbert Strauss' AND f.series LIKE '%e.s.motion vision%' AND f.model LIKE '%39A-KCI%' THEN 3\n      WHEN p.brand = 'Michelin' AND f.series LIKE '%Stealth MC%' AND f.model LIKE '%12N-18U%' THEN 4\n      WHEN p.brand = 'Keter' AND f.series LIKE '%Heavy Duty%' AND f.model LIKE '%KET 160-IR2%' THEN 5\n      WHEN p.brand = 'Osram' AND f.series LIKE '%Night Breaker Night%' AND f.model LIKE '%1EE-770%' THEN 6\n    END as target_num\n  FROM products p\n  JOIN families f ON p.family_id = f.id\n  WHERE \n    (p.brand = 'Legrand' AND f.series LIKE '%Plexo%' AND f.model LIKE '%2XT-4EJ%')\n    OR (p.brand = 'Stanley' AND f.series LIKE '%Professional%' AND f.model LIKE '%STA 1IB-RUE%')\n    OR (p.brand = 'Engelbert Strauss' AND f.series LIKE '%e.s.motion vision%' AND f.model LIKE '%39A-KCI%')\n    OR (p.brand = 'Michelin' AND f.series LIKE '%Stealth MC%' AND f.model LIKE '%12N-18U%')\n    OR (p.brand = 'Keter' AND f.series LIKE '%Heavy Duty%' AND f.model LIKE '%KET 160-IR2%')\n    OR (p.brand = 'Osram' AND f.series LIKE '%Night Breaker Night%' AND f.model LIKE '%1EE-770%')\n)\nSELECT \n  mp.target_num,\n  mp.sku,\n  MAX(CASE WHEN pp.key='device_type' AND mp.brand='Legrand' AND pp.value_text='junction box' THEN 1 ELSE 0 END) as legrand_match,\n  MAX(CASE WHEN pp.key='color_family' AND mp.brand='Legrand' AND pp.value_text='black' THEN 1 ELSE 0 END) as legrand_black,\n  MAX(CASE WHEN pp.key='storage_type' AND mp.brand='Stanley' AND pp.value_text='tool box' THEN 1 ELSE 0 END) as stanley_box,\n  MAX(CASE WHEN pp.key='color_family' AND mp.brand='Stanley' AND pp.value_text='orange' THEN 1 ELSE 0 END) as stanley_orange,\n  MAX(CASE WHEN pp.key='color_family' AND mp.brand='Engelbert Strauss' AND pp.value_text='Green' THEN 1 ELSE 0 END) as es_green,\n  MAX(CASE WHEN pp.key='size' AND mp.brand='Engelbert Strauss' AND pp.value_text='XL' THEN 1 ELSE 0 END) as es_xl,\n  MAX(CASE WHEN pp.key='fit' AND mp.brand='Engelbert Strauss' AND pp.value_text='relaxed' THEN 1 ELSE 0 END) as es_relaxed,\n  MAX(CASE WHEN pp.key='length' AND mp.brand='Michelin' AND pp.value_number=500 THEN 1 ELSE 0 END) as michelin_500,\n  MAX(CASE WHEN pp.key='adapter_type' AND mp.brand='Michelin' AND pp.value_text='multi adapter' THEN 1 ELSE 0 END) as michelin_adapter,\n  MAX(CASE WHEN pp.key='vehicle_type' AND mp.brand='Michelin' AND pp.value_text='car' THEN 1 ELSE 0 END) as michelin_car,\n  MAX(CASE WHEN pp.key='storage_type' AND mp.brand='Keter' AND pp.value_text='drawer cabinet' THEN 1 ELSE 0 END) as keter_drawer,\n  MAX(CASE WHEN pp.key='color_family' AND mp.brand='Keter' AND pp.value_text='Blue' THEN 1 ELSE 0 END) as keter_blue,\n  MAX(CASE WHEN pp.key='product_type' AND mp.brand='Osram' AND pp.value_text='jump starter' THEN 1 ELSE 0 END) as osram_jump,\n  MAX(CASE WHEN pp.key='voltage' AND mp.brand='Osram' AND pp.value_number=12 THEN 1 ELSE 0 END) as osram_12v,\n  MAX(CASE WHEN pp.key='current' AND mp.brand='Osram' AND pp.value_number=6 THEN 1 ELSE 0 END) as osram_6a,\n  MAX(CASE WHEN pp.key='vehicle_type' AND mp.brand='Osram' AND pp.value_text='universal' THEN 1 ELSE 0 END) as osram_universal\nFROM matching_products mp\nLEFT JOIN product_properties pp ON mp.sku = pp.sku\nGROUP BY mp.target_num, mp.sku;"
