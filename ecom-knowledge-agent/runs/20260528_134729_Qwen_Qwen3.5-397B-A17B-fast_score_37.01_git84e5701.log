WITH candidate_skus AS (
  SELECT 
    p.sku,
    p.brand,
    f.series,
    f.model,
    CASE 
      WHEN p.brand = 'Legrand' AND f.series LIKE '%Plexo%' AND f.model LIKE '%2XT-4EJ%' THEN 1
      WHEN p.brand = 'Stanley' AND f.series LIKE '%Professional%' AND f.model LIKE '%STA 1IB-RUE%' THEN 2
      WHEN p.brand = 'Engelbert Strauss' AND f.series LIKE '%e.s.motion vision%' AND f.model LIKE '%39A-KCI%' THEN 3
      WHEN p.brand = 'Michelin' AND f.series LIKE '%Stealth MC%' AND f.model LIKE '%12N-18U%' THEN 4
      WHEN p.brand = 'Keter' AND f.series LIKE '%Heavy Duty%' AND f.model LIKE '%KET 160-IR2%' THEN 5
      WHEN p.brand = 'Osram' AND f.series LIKE '%Night Breaker Night%' AND f.model LIKE '%1EE-770%' THEN 6
    END as target_num
  FROM products p
  JOIN families f ON p.family_id = f.id
  WHERE 
    (p.brand = 'Legrand' AND f.series LIKE '%Plexo%' AND f.model LIKE '%2XT-4EJ%')
    OR (p.brand = 'Stanley' AND f.series LIKE '%Professional%' AND f.model LIKE '%STA 1IB-RUE%')
    OR (p.brand = 'Engelbert Strauss' AND f.series LIKE '%e.s.motion vision%' AND f.model LIKE '%39A-KCI%')
    OR (p.brand = 'Michelin' AND f.series LIKE '%Stealth MC%' AND f.model LIKE '%12N-18U%')
    OR (p.brand = 'Keter' AND f.series LIKE '%Heavy Duty%' AND f.model LIKE '%KET 160-IR2%')
    OR (p.brand = 'Osram' AND f.series LIKE '%Night Breaker Night%' AND f.model LIKE '%1EE-770%')
),
product_matches AS (
  SELECT 
    cs.target_num,
    cs.sku,
    cs.brand,
    -- Legrand: device_type='junction box' AND color_family='Black'
    MAX(CASE WHEN pp.key='device_type' AND LOWER(pp.value_text)=LOWER('junction box') THEN 1 ELSE 0 END) as has_device_type,
    MAX(CASE WHEN pp.key='color_family' AND LOWER(pp.value_text)=LOWER('Black') THEN 1 ELSE 0 END) as has_color,
    -- Stanley: storage_type='tool box' AND color_family='Orange'
    MAX(CASE WHEN pp.key='storage_type' AND LOWER(pp.value_text)=LOWER('tool box') THEN 1 ELSE 0 END) as has_storage_type,
    MAX(CASE WHEN pp.key='color_family' AND LOWER(pp.value_text)=LOWER('Orange') THEN 1 ELSE 0 END) as has_orange,
    -- Engelbert Strauss: color_family='Green' AND size='XL' AND fit='relaxed'
    MAX(CASE WHEN pp.key='color_family' AND LOWER(pp.value_text)=LOWER('Green') THEN 1 ELSE 0 END) as has_green,
    MAX(CASE WHEN pp.key='size' AND LOWER(pp.value_text)=LOWER('XL') THEN 1 ELSE 0 END) as has_xl,
    MAX(CASE WHEN pp.key='fit' AND LOWER(pp.value_text)=LOWER('relaxed') THEN 1 ELSE 0 END) as has_relaxed,
    -- Michelin: length=500 AND adapter_type='multi adapter' AND vehicle_type='car'
    MAX(CASE WHEN pp.key='length' AND pp.value_number=500 THEN 1 ELSE 0 END) as has_length_500,
    MAX(CASE WHEN pp.key='adapter_type' AND LOWER(pp.value_text)=LOWER('multi adapter') THEN 1 ELSE 0 END) as has_adapter,
    MAX(CASE WHEN pp.key='vehicle_type' AND LOWER(pp.value_text)=LOWER('car') THEN 1 ELSE 0 END) as has_vehicle_car,
    -- Keter: storage_type='drawer cabinet' AND color_family='Blue'
    MAX(CASE WHEN pp.key='storage_type' AND LOWER(pp.value_text)=LOWER('drawer cabinet') THEN 1 ELSE 0 END) as has_drawer,
    MAX(CASE WHEN pp.key='color_family' AND LOWER(pp.value_text)=LOWER('Blue') THEN 1 ELSE 0 END) as has_blue,
    -- Osram: product_type='jump starter' AND voltage=12 AND current=6 AND vehicle_type='universal'
    MAX(CASE WHEN pp.key='product_type' AND LOWER(pp.value_text)=LOWER('jump starter') THEN 1 ELSE 0 END) as has_jump_starter,
    MAX(CASE WHEN pp.key='voltage' AND pp.value_number=12 THEN 1 ELSE 0 END) as has_12v,
    MAX(CASE WHEN pp.key='current' AND pp.value_number=6 THEN 1 ELSE 0 END) as has_6a,
    MAX(CASE WHEN pp.key='vehicle_type' AND LOWER(pp.value_text)=LOWER('universal') THEN 1 ELSE 0 END) as has_universal
  FROM candidate_skus cs
  LEFT JOIN product_properties pp ON cs.sku = pp.sku
  GROUP BY cs.target_num, cs.sku, cs.brand
),
fully_matched AS (
  SELECT 
    target_num,
    sku,
    brand,
    CASE WHEN brand='Legrand' AND has_device_type=1 AND has_color=1 THEN 1 ELSE 0 END as legrand_ok,
    CASE WHEN brand='Stanley' AND has_storage_type=1 AND has_orange=1 THEN 1 ELSE 0 END as stanley_ok,
    CASE WHEN brand='Engelbert Strauss' AND has_green=1 AND has_xl=1 AND has_relaxed=1 THEN 1 ELSE 0 END as es_ok,
    CASE WHEN brand='Michelin' AND has_length_500=1 AND has_adapter=1 AND has_vehicle_car=1 THEN 1 ELSE 0 END as michelin_ok,
    CASE WHEN brand='Keter' AND has_drawer=1 AND has_blue=1 THEN 1 ELSE 0 END as keter_ok,
    CASE WHEN brand='Osram' AND has_jump_starter=1 AND has_12v=1 AND has_6a=1 AND has_universal=1 THEN 1 ELSE 0 END as osram_ok
  FROM product_matches
)
SELECT 
  fm.target_num,
  fm.sku,
  fm.brand,
  fm.legrand_ok + fm.stanley_ok + fm.es_ok + fm.michelin_ok + fm.keter_ok + fm.osram_ok as is_fully_matched,
  i.available_today
FROM fully_matched fm
LEFT JOIN inventory i ON fm.sku = i.sku AND i.store_id = 'store_brno_veveri'
WHERE (fm.legrand_ok + fm.stanley_ok + fm.es_ok + fm.michelin_ok + fm.keter_ok + fm.osram_ok) = 1
ORDER BY fm.target_num, fm.sku;
