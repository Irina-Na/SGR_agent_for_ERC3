  OR (cs.brand = 'Engelbert Strauss' AND LOWER(pp_color.value_text) = LOWER('green') AND LOWER(pp_size.value_text) = LOWER('xl') AND LOWER(pp_fit.value_text) = LOWER('relaxed'))
  OR (cs.brand = 'Michelin' AND pp_length.value_number = 500 AND LOWER(pp_adapter.value_text) = LOWER('multi adapter') AND LOWER(pp_vehicle.value_text) = LOWER('car'))
