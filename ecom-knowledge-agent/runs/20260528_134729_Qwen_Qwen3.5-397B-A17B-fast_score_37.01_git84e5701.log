LEFT JOIN product_properties pp_voltage ON cs.sku = pp_voltage.sku AND pp_voltage.key='voltage'
LEFT JOIN product_properties pp_current ON cs.sku = pp_current.sku AND pp_current.key='current'
LEFT JOIN inventory i ON cs.sku = i.sku AND i.store_id = 'store_brno_veveri'
