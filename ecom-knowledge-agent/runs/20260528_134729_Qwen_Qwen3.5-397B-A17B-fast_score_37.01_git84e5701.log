WITH target_products AS (
  SELECT 
    p.sku,
    p.brand,
    f.series,
    f.model,
    f.name as family_name,
    p.kind_id,
    CASE 
      WHEN p.brand = 'Legrand' AND f.series LIKE '%Plexo%' AND f.model LIKE '%2XT-4EJ%' THEN 'product_1'
      WHEN p.brand = 'Stanley' AND f.series LIKE '%Professional%' AND f.model LIKE '%STA 1IB-RUE%' THEN 'product_2'
      WHEN p.brand = 'Engelbert Strauss' AND f.series LIKE '%e.s.motion vision%' AND f.model LIKE '%39A-KCI%' THEN 'product_3'
      WHEN p.brand = 'Michelin' AND f.series LIKE '%Stealth MC%' AND f.model LIKE '%12N-18U%' THEN 'product_4'
      WHEN p.brand = 'Keter' AND f.series LIKE '%Heavy Duty%' AND f.model LIKE '%KET 160-IR2%' THEN 'product_5'
      WHEN p.brand = 'Osram' AND f.series LIKE '%Night Breaker Night%' AND f.model LIKE '%1EE-770%' THEN 'product_6'
    END as target_id
  FROM products p
  JOIN families f ON p.family_id = f.id
  WHERE 
    (p.brand = 'Legrand' AND f.series LIKE '%Plexo%' AND f.model LIKE '%2XT-4EJ%')
    OR (p.brand = 'Stanley' AND f.series LIKE '%Professional%' AND f.model LIKE '%STA 1IB-RUE%')
    OR (p.brand = 'Engelbert Strauss' AND f.series LIKE '%e.s.motion vision%' AND f.model LIKE '%39A-KCI%')
    OR (p.brand = 'Michelin' AND f.series LIKE '%Stealth MC%' AND f.model LIKE '%12N-18U%')
    OR (p.brand = 'Keter' AND f.series LIKE '%Heavy Duty%' AND f.model LIKE '%KET 160-IR2%')
    OR (p.brand = 'Osram' AND f.series LIKE '%Night Breaker Night%' AND f.model LIKE '%1EE-770%')
)
SELECT 
  tp.target_id,
  tp.sku,
  tp.brand,
  tp.series,
  tp.model,
  pp_device.value_text as device_type,
  pp_storage.value_text as storage_type,
  pp_color.value_text as color_family,
  pp_size.value_text as size,
  pp_fit.value_text as fit,
  pp_length.value_number as length_mm,
  pp_adapter.value_text as adapter_type,
  pp_vehicle.value_text as vehicle_type,
  pp_product_type.value_text as product_type,
  pp_voltage.value_number as voltage,
  pp_current.value_number as current_a,
  i.available_today
FROM target_products tp
LEFT JOIN product_properties pp_device ON tp.sku = pp_device.sku AND pp_device.key = 'device_type'
LEFT JOIN product_properties pp_storage ON tp.sku = pp_storage.sku AND pp_storage.key = 'storage_type'
LEFT JOIN product_properties pp_color ON tp.sku = pp_color.sku AND pp_color.key = 'color_family'
LEFT JOIN product_properties pp_size ON tp.sku = pp_size.sku AND pp_size.key = 'size'
LEFT JOIN product_properties pp_fit ON tp.sku = pp_fit.sku AND pp_fit.key = 'fit'
LEFT JOIN product_properties pp_length ON tp.sku = pp_length.sku AND pp_length.key = 'length'
LEFT JOIN product_properties pp_adapter ON tp.sku = pp_adapter.sku AND pp_adapter.key = 'adapter_type'
LEFT JOIN product_properties pp_vehicle ON tp.sku = pp_vehicle.sku AND pp_vehicle.key = 'vehicle_type'
LEFT JOIN product_properties pp_product_type ON tp.sku = pp_product_type.sku AND pp_product_type.key = 'product_type'
LEFT JOIN product_properties pp_voltage ON tp.sku = pp_voltage.sku AND pp_voltage.key = 'voltage'
LEFT JOIN product_properties pp_current ON tp.sku = pp_current.sku AND pp_current.key = 'current'
LEFT JOIN inventory i ON tp.sku = i.sku AND i.store_id = 'store_brno_veveri'
ORDER BY tp.target_id;
