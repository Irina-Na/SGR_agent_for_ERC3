  LEFT JOIN product_properties pp_adapter ON p.sku = pp_adapter.sku AND pp_adapter.key='adapter_type'
  LEFT JOIN product_properties pp_vehicle ON p.sku = pp_vehicle.sku AND pp_vehicle.key='vehicle_type'
  LEFT JOIN product_properties pp_product_type ON p.sku = pp_product_type.sku AND pp_product_type.key='product_type'
  LEFT JOIN product_properties pp_voltage ON p.sku = pp_voltage.sku AND pp_voltage.key='voltage'
  LEFT JOIN product_properties pp_current ON p.sku = pp_current.sku AND pp_current.key='current'
  LEFT JOIN inventory i ON p.sku = i.sku AND i.store_id = 'store_brno_veveri'
  WHERE 
    (p.brand = 'Legrand' AND LOWER(pp_device.value_text) = LOWER('junction box') AND LOWER(pp_color.value_text) = LOWER('black'))
    OR (p.brand = 'Stanley' AND LOWER(pp_storage.value_text) = LOWER('tool box') AND LOWER(pp_color.value_text) = LOWER('orange'))
    OR (p.brand = 'Engelbert Strauss' AND LOWER(pp_color.value_text) = LOWER('green') AND LOWER(pp_size.value_text) = LOWER('xl') AND LOWER(pp_fit.value_text) = LOWER('relaxed'))
    OR (p.brand = 'Michelin' AND pp_length.value_number = 500 AND LOWER(pp_adapter.value_text) = LOWER('multi adapter') AND LOWER(pp_vehicle.value_text) = LOWER('car'))
    OR (p.brand = 'Keter' AND LOWER(pp_storage.value_text) = LOWER('drawer cabinet') AND LOWER(pp_color.value_text) = LOWER('blue'))
    OR (p.brand = 'Osram' AND LOWER(pp_product_type.value_text) = LOWER('jump starter') AND pp_voltage.value_number = 12 AND pp_current.value_number = 6 AND LOWER(pp_vehicle.value_text) = LOWER('universal'))
)
