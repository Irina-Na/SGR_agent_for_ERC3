LEFT JOIN product_properties pp_device ON cs.sku = pp_device.sku AND pp_device.key='device_type'
LEFT JOIN product_properties pp_color ON cs.sku = pp_color.sku AND pp_color.key='color_family'
LEFT JOIN product_properties pp_storage ON cs.sku = pp_storage.sku AND pp_storage.key='storage_type'
LEFT JOIN product_properties pp_size ON cs.sku = pp_size.sku AND pp_size.key='size'
LEFT JOIN product_properties pp_fit ON cs.sku = pp_fit.sku AND pp_fit.key='fit'
LEFT JOIN product_properties pp_length ON cs.sku = pp_length.sku AND pp_length.key='length'
