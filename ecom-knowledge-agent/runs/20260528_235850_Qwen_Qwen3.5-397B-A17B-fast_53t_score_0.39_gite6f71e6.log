	FOREIGN KEY (product_sku) REFERENCES product_variants(product_sku)
)"
payment_transactions,"CREATE TABLE payment_transactions (
	payment_id TEXT PRIMARY KEY,
	record_path TEXT NOT NULL,
	basket_id TEXT NOT NULL,
