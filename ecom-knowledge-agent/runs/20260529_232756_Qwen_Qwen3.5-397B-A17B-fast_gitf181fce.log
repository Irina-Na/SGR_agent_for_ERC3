customer_accounts,"CREATE TABLE customer_accounts (
	customer_id TEXT PRIMARY KEY,
	record_path TEXT NOT NULL,
	customer_display_name TEXT NOT NULL,
	customer_email TEXT NOT NULL,
	home_city TEXT NOT NULL,
