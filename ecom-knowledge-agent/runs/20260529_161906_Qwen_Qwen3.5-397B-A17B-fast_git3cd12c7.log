Next step_3... Query product_variants and product_variant_properties to identify each of the 6 products by their unique criteria (5262 ms)
  tool='exec' path='/bin/sql' args=[] stdin="WITH product_criteria AS (\n  SELECT 'Milwaukee' as brand, 'Heavy Duty FUEL' as series, '15U-VFS' as model, 'Tool Box and Bag' as product_name, 'storage_type' as prop1_key, 'tool box' as prop1_val, 'color_family' as prop2_key, 'Clear' as prop2_val, 1 as product_num UNION ALL\n  SELECT 'Stanley', 'Professional', 'FM 39X-HFQ', 'Storage Bin and Organizer', 'storage_type', 'organizer', 'color_family', 'Gray', 2 UNION ALL\n  SELECT 'Caparol', 'CapaSilan Capa', '1I7-X1P', 'Metal and Concrete Paint', 'product_type', 'metal paint', 'color_family', 'Gray', 3 UNION ALL\n  SELECT 'Leifheit', 'Profi Clean', '82J-3JB', 'Cloth Mop and Wipe', 'cleaning_type', 'workshop wipes', 'pack_count', '5 pcs', 4 UNION ALL\n  SELECT 'Dickies', 'Classic Redhawk', 'Q3G-7LF', 'Work Top', 'garment_type', 'polo shirt', 'color_family', 'Orange', 5 UNION ALL\n  SELECT 'Leifheit', 'Clean Twist Profi', '1SY-SM8', 'Cloth Mop and Wipe', 'cleaning_type', 'mop system', 'pack_count', '5 pcs', 6\n)\nSELECT pc.product_num, pv.product_sku, pv.brand, pv.series, pv.model, pv.product_name\nFROM product_criteria pc\nJOIN product_variants pv ON pv.brand = pc.brand AND pv.series = pc.series AND pv.model = pc.model AND pv.product_name = pc.product_name\nJOIN product_variant_properties pvp1 ON pvp1.product_sku = pv.product_sku AND pvp1.property_key = pc.prop1_key AND pvp1.property_value_text = pc.prop1_val\nJOIN product_variant_properties pvp2 ON pvp2.product_sku = pv.product_sku AND pvp2.property_key = pc.prop2_key AND pvp2.property_value_text = pc.prop2_val;\n"
[32mOUT[0m: /bin/sql <<'SQL'
WITH product_criteria AS (
  SELECT 'Milwaukee' as brand, 'Heavy Duty FUEL' as series, '15U-VFS' as model, 'Tool Box and Bag' as product_name, 'storage_type' as prop1_key, 'tool box' as prop1_val, 'color_family' as prop2_key, 'Clear' as prop2_val, 1 as product_num UNION ALL
  SELECT 'Stanley', 'Professional', 'FM 39X-HFQ', 'Storage Bin and Organizer', 'storage_type', 'organizer', 'color_family', 'Gray', 2 UNION ALL
  SELECT 'Caparol', 'CapaSilan Capa', '1I7-X1P', 'Metal and Concrete Paint', 'product_type', 'metal paint', 'color_family', 'Gray', 3 UNION ALL
  SELECT 'Leifheit', 'Profi Clean', '82J-3JB', 'Cloth Mop and Wipe', 'cleaning_type', 'workshop wipes', 'pack_count', '5 pcs', 4 UNION ALL
  SELECT 'Dickies', 'Classic Redhawk', 'Q3G-7LF', 'Work Top', 'garment_type', 'polo shirt', 'color_family', 'Orange', 5 UNION ALL
  SELECT 'Leifheit', 'Clean Twist Profi', '1SY-SM8', 'Cloth Mop and Wipe', 'cleaning_type', 'mop system', 'pack_count', '5 pcs', 6
)
SELECT pc.product_num, pv.product_sku, pv.brand, pv.series, pv.model, pv.product_name
FROM product_criteria pc
JOIN product_variants pv ON pv.brand = pc.brand AND pv.series = pc.series AND pv.model = pc.model AND pv.product_name = pc.product_name
JOIN product_variant_properties pvp1 ON pvp1.product_sku = pv.product_sku AND pvp1.property_key = pc.prop1_key AND pvp1.property_value_text = pc.prop1_val
JOIN product_variant_properties pvp2 ON pvp2.product_sku = pv.product_sku AND pvp2.property_key = pc.prop2_key AND pvp2.property_value_text = pc.prop2_val;
SQL
product_num,product_sku,brand,series,model,product_name
