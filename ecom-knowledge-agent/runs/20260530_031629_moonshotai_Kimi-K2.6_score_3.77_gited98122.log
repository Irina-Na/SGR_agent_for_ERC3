)"
store_inventory,"CREATE TABLE store_inventory (
	store_id TEXT NOT NULL,
	product_sku TEXT NOT NULL,
	on_hand_quantity INTEGER NOT NULL,
	reserved_quantity INTEGER NOT NULL,
	available_today_quantity INTEGER NOT NULL,
