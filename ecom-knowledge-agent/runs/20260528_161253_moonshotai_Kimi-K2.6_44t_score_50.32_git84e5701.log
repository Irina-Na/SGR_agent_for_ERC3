uct_properties pp2 ON pp2.sku = p.sku AND pp2.key = 'color_family' AND pp2.value_text = 'black'\n  JOIN product_properties pp3 ON pp3.sku = p.sku AND pp3.key = 'protection_class' AND pp3.value_text = 'cut-3'\n  WHERE p.family_id = 'fam_safety_gear_work_gloves_0001_1v59xqjt'\n  UNION ALL\n  SELECT p.sku, 'Sikkens Professional Wall Paint'\n  FROM products p\n  JOIN product_properties pp1 ON pp1.sku = p.sku AND pp1.key = 'color_family' AND pp1.value_text = 'yellow'\n  JOIN product_properties pp2 ON pp2.sku = p.sku AND pp2.key = 'finish' AND pp2.value_text = 'gloss'\n  WHERE p.family_id = 'fam_paints_finishes_wall_paint_0002_238j473n'\n)\nSELECT t.sku, t.desc, COALESCE(i.available_today, 0) AS available_today\nFROM targets t\nLEFT JOIN inventory i ON i.sku = t.sku AND i.store_id = 'store_brno_veveri'\nORDER BY t.desc;"] stdin=''
