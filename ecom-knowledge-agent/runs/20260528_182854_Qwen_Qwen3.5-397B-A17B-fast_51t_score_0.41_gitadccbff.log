WITH product_matches AS (
  SELECT pv.product_sku, pv.brand, pv.series, pv.product_name,
         MAX(CASE WHEN pvp.property_key = 'fitting_type' AND pvp.property_value_text = 'pipe fitting' THEN 1 ELSE 0 END) as viega_fitting,
         MAX(CASE WHEN pvp.property_key = 'diameter' AND pvp.property_value_text = '15 mm' THEN 1 ELSE 0 END) as viega_diameter,
         MAX(CASE WHEN pvp.property_key = 'connection_type' AND pvp.property_value_text = 'threaded' THEN 1 ELSE 0 END) as viega_connection,
         MAX(CASE WHEN pvp.property_key = 'voltage' AND pvp.property_value_text = '18 V' THEN 1 ELSE 0 END) as metabo_voltage,
         MAX(CASE WHEN pvp.property_key = 'battery_platform' AND pvp.property_value_text = '18v-system' THEN 1 ELSE 0 END) as metabo_battery,
         MAX(CASE WHEN pvp.property_key = 'kit_contents' AND pvp.property_value_text = 'bare tool' THEN 1 ELSE 0 END) as metabo_kit,
         MAX(CASE WHEN pvp.property_key = 'storage_type' AND pvp.property_value_text = 'parts case' THEN 1 ELSE 0 END) as keter_storage,
         MAX(CASE WHEN pvp.property_key = 'color_family' AND pvp.property_value_text = 'Yellow' THEN 1 ELSE 0 END) as keter_color,
         MAX(CASE WHEN pvp.property_key = 'volume' AND pvp.property_value_text = '8 l' THEN 1 ELSE 0 END) as keter_volume,
         MAX(CASE WHEN pvp.property_key = 'cleaner_type' AND pvp.property_value_text = 'polish' THEN 1 ELSE 0 END) as sonax_cleaner,
         MAX(CASE WHEN pvp.property_key = 'screw_type' AND pvp.property_value_text = 'wood screw' THEN 1 ELSE 0 END) as dresselhaus_type,
         MAX(CASE WHEN pvp.property_key = 'diameter' AND pvp.property_value_text = '5 mm' THEN 1 ELSE 0 END) as dresselhaus_diameter,
         MAX(CASE WHEN pvp.property_key = 'tool_type' AND pvp.property_value_text = 'clamp' THEN 1 ELSE 0 END) as bahco_clamp
  FROM product_variants pv
  LEFT JOIN product_variant_properties pvp ON pv.product_sku = pvp.product_sku
  WHERE pv.brand IN ('Viega', 'Metabo', 'Keter', 'Sonax', 'Dresselhaus', 'Bahco')
  GROUP BY pv.product_sku, pv.brand, pv.series, pv.product_name
),
matched_products AS (
  SELECT product_sku,
         CASE WHEN brand = 'Viega' AND viega_fitting = 1 AND viega_diameter = 1 AND viega_connection = 1 THEN 1 ELSE 0 END as match_viega,
         CASE WHEN brand = 'Metabo' AND metabo_voltage = 1 AND metabo_battery = 1 AND metabo_kit = 1 THEN 1 ELSE 0 END as match_metabo,
         CASE WHEN brand = 'Keter' AND keter_storage = 1 AND keter_color = 1 AND keter_volume = 1 THEN 1 ELSE 0 END as match_keter,
         CASE WHEN brand = 'Sonax' AND sonax_cleaner = 1 THEN 1 ELSE 0 END as match_sonax,
         CASE WHEN brand = 'Dresselhaus' AND dresselhaus_type = 1 AND dresselhaus_diameter = 1 THEN 1 ELSE 0 END as match_dresselhaus,
         CASE WHEN brand = 'Bahco' AND bahco_clamp = 1 THEN 1 ELSE 0 END as match_bahco
  FROM product_matches
),
final_matches AS (
  SELECT product_sku FROM matched_products
  WHERE match_viega = 1 OR match_metabo = 1 OR match_keter = 1 OR match_sonax = 1 OR match_dresselhaus = 1 OR match_bahco = 1
)
SELECT fm.product_sku, si.available_today_quantity
FROM final_matches fm
JOIN store_inventory si ON fm.product_sku = si.product_sku
WHERE si.store_id = 'store_ljubljana_center' AND si.available_today_quantity >= 3;
