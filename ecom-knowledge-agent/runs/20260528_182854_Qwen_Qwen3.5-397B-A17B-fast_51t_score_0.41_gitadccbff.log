WITH target_products AS (
  SELECT pv.product_sku, pv.brand, pv.series, pv.product_name
  FROM product_variants pv
  JOIN product_variant_properties pvp ON pv.product_sku = pvp.product_sku
  WHERE (
    -- 1. Viega Pipe Fitting: brand=Viega, series contains Sanpress, fitting type=pipe fitting, diameter=15mm, connection=threaded
    (pv.brand = 'Viega' AND pv.series LIKE '%Sanpress%' AND pv.product_name LIKE '%Pipe Fitting%')
    OR
    -- 2. Metabo Cordless Drill: brand=Metabo, series contains Brushless BS, voltage=18V, battery=18v-system, kit=bare tool
    (pv.brand = 'Metabo' AND pv.series LIKE '%Brushless BS%' AND pv.product_name LIKE '%Cordless Drill%')
    OR
    -- 3. Keter Storage Bin: brand=Keter, series contains Deep Stack, storage type=parts case, color=Yellow, volume=8l
    (pv.brand = 'Keter' AND pv.series LIKE '%Deep Stack%' AND pv.product_name LIKE '%Storage Bin%')
    OR
    -- 4. Sonax Automotive Cleaner: brand=Sonax, series contains Workshop XTREME, cleaner type=polish
    (pv.brand = 'Sonax' AND pv.series LIKE '%Workshop XTREME%' AND pv.product_name LIKE '%Automotive Cleaner%')
    OR
    -- 5. Dresselhaus Wood Screw: brand=Dresselhaus, series contains Outdoor Pro, screw type=wood screw, diameter=5mm
    (pv.brand = 'Dresselhaus' AND pv.series LIKE '%Outdoor Pro%' AND pv.product_name LIKE '%Wood and Drywall Screw%')
    OR
    -- 6. Bahco Hammer Tool: brand=Bahco, series contains Workshop, tool type=clamp
    (pv.brand = 'Bahco' AND pv.series LIKE '%Workshop%' AND pv.product_name LIKE '%Hammer%')
  )
  GROUP BY pv.product_sku
)
