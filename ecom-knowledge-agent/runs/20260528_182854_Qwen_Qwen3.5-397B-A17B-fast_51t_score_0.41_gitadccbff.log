_value_text = 'Red' THEN 1 END) >= 1\n),\ndickies_match AS (\n  SELECT pv.product_sku\n  FROM product_variants pv\n  JOIN product_variant_properties pvp ON pv.product_sku = pvp.product_sku\n  WHERE pv.brand = 'Dickies' AND pv.series = 'Fleece Redhawk' AND pv.model = 'MRB-WYE'\n  GROUP BY pv.product_sku\n  HAVING COUNT(CASE WHEN pvp.property_key = 'garment_type' AND pvp.property_value_text = 't-shirt' THEN 1 END) >= 1\n     AND COUNT(CASE WHEN pvp.property_key = 'color_family' AND pvp.property_value_text = 'Black' THEN 1 END) >= 1\n     AND COUNT(CASE WHEN pvp.property_key = 'size' AND pvp.property_value_text = 'XL' THEN 1 END) >= 1\n)\nSELECT 'sikkens' as product, product_sku FROM sikkens_match\nUNION ALL SELECT 'bosch', product_sku FROM bosch_match\nUNION ALL SELECT 'stanley', product_sku FROM stanley_match\nUNION ALL SELECT 'caparol', product_sku FROM caparol_match\nUNION ALL SELECT 'dickies', product_sku FROM dickies_match;"
[32mOUT[0m: /bin/sql <<'SQL'
WITH sikkens_match AS (
  SELECT pv.product_sku
  FROM product_variants pv
  JOIN product_variant_properties pvp ON pv.product_sku = pvp.product_sku
  WHERE pv.brand = 'Sikkens' AND pv.series = 'Cetol Rubbol' AND pv.model = '1KE-GBP'
  GROUP BY pv.product_sku
  HAVING COUNT(CASE WHEN pvp.property_key = 'product_type' AND pvp.property_value_text = 'primer' THEN 1 END) >= 1
     AND COUNT(CASE WHEN pvp.property_key = 'color_family' AND pvp.property_value_text = 'Black' THEN 1 END) >= 1
     AND COUNT(CASE WHEN pvp.property_key = 'finish' AND pvp.property_value_text = 'transparent' THEN 1 END) >= 1
),
bosch_match AS (
  SELECT pv.product_sku
  FROM product_variants pv
  JOIN product_variant_properties pvp ON pv.product_sku = pvp.product_sku
  WHERE pv.brand = 'Bosch' AND pv.series = 'Universal BBS' AND pv.model = 'LS3-D02'
  GROUP BY pv.product_sku
  HAVING COUNT(CASE WHEN pvp.property_key = 'machine_type' AND pvp.property_value_text = 'drill press' THEN 1 END) >= 1
),
stanley_match AS (
  SELECT pv.product_sku
  FROM product_variants pv
  JOIN product_variant_properties pvp ON pv.product_sku = pvp.product_sku
  WHERE pv.brand = 'Stanley' AND pv.series = 'Classic' AND pv.model = 'STA CEQ-WUX'
  GROUP BY pv.product_sku
  HAVING COUNT(CASE WHEN pvp.property_key = 'storage_type' AND pvp.property_value_text = 'sortainer' THEN 1 END) >= 1
     AND COUNT(CASE WHEN pvp.property_key = 'color_family' AND pvp.property_value_text = 'Clear' THEN 1 END) >= 1
),
caparol_match AS (
  SELECT pv.product_sku
  FROM product_variants pv
  JOIN product_variant_properties pvp ON pv.product_sku = pvp.product_sku
  WHERE pv.brand = 'Caparol' AND pv.series = 'Premium Capa' AND pv.model = '32D-5X8'
  GROUP BY pv.product_sku
  HAVING COUNT(CASE WHEN pvp.property_key = 'product_type' AND pvp.property_value_text = 'facade paint' THEN 1 END) >= 1
     AND COUNT(CASE WHEN pvp.property_key = 'color_family' AND pvp.property_value_text = 'Red' THEN 1 END) >= 1
),
dickies_match AS (
  SELECT pv.product_sku
  FROM product_variants pv
  JOIN product_variant_properties pvp ON pv.product_sku = pvp.product_sku
  WHERE pv.brand = 'Dickies' AND pv.series = 'Fleece Redhawk' AND pv.model = 'MRB-WYE'
  GROUP BY pv.product_sku
  HAVING COUNT(CASE WHEN pvp.property_key = 'garment_type' AND pvp.property_value_text = 't-shirt' THEN 1 END) >= 1
     AND COUNT(CASE WHEN pvp.property_key = 'color_family' AND pvp.property_value_text = 'Black' THEN 1 END) >= 1
     AND COUNT(CASE WHEN pvp.property_key = 'size' AND pvp.property_value_text = 'XL' THEN 1 END) >= 1
)
SELECT 'sikkens' as product, product_sku FROM sikkens_match
UNION ALL SELECT 'bosch', product_sku FROM bosch_match
UNION ALL SELECT 'stanley', product_sku FROM stanley_match
UNION ALL SELECT 'caparol', product_sku FROM caparol_match
UNION ALL SELECT 'dickies', product_sku FROM dickies_match;
