WITH product_matches AS (
  SELECT pv.product_sku, pv.brand, pv.series, pv.model,
         'uponor_pipe_fitting' as target_product,
         COUNT(CASE WHEN pvp.property_key = 'fitting_type' AND pvp.property_value_text = 'thread adapter' THEN 1 END) as fitting_type_match,
         COUNT(CASE WHEN pvp.property_key = 'diameter' AND pvp.property_value_text = '25 mm' THEN 1 END) as diameter_match,
         COUNT(CASE WHEN pvp.property_key = 'connection_type' AND pvp.property_value_text = 'press' THEN 1 END) as connection_match
  FROM product_variants pv
  JOIN product_variant_properties pvp ON pv.product_sku = pvp.product_sku
  WHERE pv.brand = 'Uponor' AND pv.series = 'Press Fit Aqua' AND pv.model = '35M-6XO'
  GROUP BY pv.product_sku
  HAVING fitting_type_match >= 1 AND diameter_match >= 1 AND connection_match >= 1
)
SELECT product_sku FROM product_matches;
