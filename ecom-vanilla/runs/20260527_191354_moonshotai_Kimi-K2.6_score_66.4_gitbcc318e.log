# /bin/sql

Run a read-only SQLite query over the ecommerce world.

Send SQL on stdin, or pass SQL as arguments:

  /bin/sql 'select sku, name, path from products limit 5'

Default output is CSV with a header row. Pass --json for JSON rows.

SQLite exposes the schema through sqlite_schema:

  /bin/sql 'select name, sql from sqlite_schema where sql is not null order by type, name;'

Useful tables:

- categories(id, name, department)
- product_kinds(id, category_id, name)
- families(id, category_id, kind_id, brand, series, model, name, properties)
- products(sku, path, category_id, kind_id, family_id, brand, series, model, name, price_cents, price_currency, properties)
- product_properties(sku, key, value_text, value_number)
- stores(id, path, name, city, is_open, lat, lon)
- inventory(store_id, sku, on_hand, reserved, available_today, incoming_quantity, next_arrival_in_days)
- employees(id, path, display_name, email, title, store_id)
- employee_roles(employee_id, role)
- customers(id, path, display_name, email, city, home_lat, home_lon)
- baskets(id, path, customer_id, store_id, status, created_at, discount_percent, discount_reason_code, discount_issuer_id)
- basket_lines(basket_id, line_no, sku, quantity)
- payments(id, path, basket_id, basket_archived, customer_id, store_id, amount_cents, currency, status, created_at, payment_method_fingerprint, device_fingerprint, observed_lat, observed_lon, three_ds_status, three_ds_failure_reason, three_ds_attempts, three_ds_max_attempts)
- payment_lines(payment_id, line_no, sku, quantity, unit_price_cents)
- returns(id, path, basket_id, customer_id, payment_id, status, reason_code, created_at)
