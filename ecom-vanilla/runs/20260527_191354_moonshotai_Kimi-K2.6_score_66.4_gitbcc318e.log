RE f.brand = 'Rust-Oleum' AND f.series = 'Exterior' AND f.model = '38D-69D'\n  GROUP BY p.sku\n  HAVING SUM(CASE WHEN pp.key = 'product_type' AND pp.value_text = 'primer' THEN 1 ELSE 0 END) > 0\n  UNION ALL\n  SELECT p.sku, p.path\n  FROM products p\n  JOIN families f ON f.id = p.family_id\n  JOIN product_properties pp ON pp.sku = p.sku\n  WHERE f.brand = 'Leifheit' AND f.series = 'Fresh Profi' AND f.model = 'NBC-KFA'\n  GROUP BY p.sku\n  HAVING SUM(CASE WHEN pp.key = 'cleaning_type' AND pp.value_text = 'mop system' THEN 1 ELSE 0 END) > 0\n     AND SUM(CASE WHEN pp.key = 'pack_count' AND pp.value_text = '5 pcs' THEN 1 ELSE 0 END) > 0\n)\nSELECT t.sku, t.path, i.available_today\nFROM matched_skus t\nLEFT JOIN inventory i ON i.sku = t.sku AND i.store_id = 'store_vienna_praterstern'\nWHERE i.available_today >= 4;"
