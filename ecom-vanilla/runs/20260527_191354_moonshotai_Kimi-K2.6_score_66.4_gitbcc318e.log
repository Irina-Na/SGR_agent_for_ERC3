  JOIN families f ON f.id = p.family_id
  JOIN product_properties pp ON pp.sku = p.sku
  WHERE f.brand = 'Schneider Electric' AND f.series = 'Indoor Merten' AND f.model = 'NF0-X1M'
  GROUP BY p.sku
  HAVING SUM(CASE WHEN pp.key = 'color_family' AND pp.value_text = 'Gray' THEN 1 ELSE 0 END) > 0
  UNION ALL
  SELECT p.sku, p.path
  FROM products p
  JOIN families f ON f.id = p.family_id
  JOIN product_properties pp ON pp.sku = p.sku
  WHERE f.brand = 'Milwaukee' AND f.series = 'Professional FUEL' AND f.model = 'NRG-ONK'
  GROUP BY p.sku
  HAVING SUM(CASE WHEN pp.key = 'voltage' AND pp.value_text = '12 V' THEN 1 ELSE 0 END) > 0
     AND SUM(CASE WHEN pp.key = 'battery_platform' AND pp.value_text = '12v-system' THEN 1 ELSE 0 END) > 0
     AND SUM(CASE WHEN pp.key = 'kit_contents' AND pp.value_text = 'two battery kit' THEN 1 ELSE 0 END) > 0
  UNION ALL
  SELECT p.sku, p.path
  FROM products p
  JOIN families f ON f.id = p.family_id
  JOIN product_properties pp ON pp.sku = p.sku
  WHERE f.brand = 'Ajax' AND f.series = 'Pro Classic' AND f.model = '1UB-9BB'
  GROUP BY p.sku
  HAVING SUM(CASE WHEN pp.key = 'cleaning_type' AND pp.value_text = 'broom set' THEN 1 ELSE 0 END) > 0
     AND SUM(CASE WHEN pp.key = 'pack_count' AND pp.value_text = '1 pcs' THEN 1 ELSE 0 END) > 0
  UNION ALL
  SELECT p.sku, p.path
  FROM products p
  JOIN families f ON f.id = p.family_id
  JOIN product_properties pp ON pp.sku = p.sku
  WHERE f.brand = 'Rust-Oleum' AND f.series = 'Exterior' AND f.model = '38D-69D'
  GROUP BY p.sku
  HAVING SUM(CASE WHEN pp.key = 'product_type' AND pp.value_text = 'primer' THEN 1 ELSE 0 END) > 0
  UNION ALL
  SELECT p.sku, p.path
  FROM products p
  JOIN families f ON f.id = p.family_id
  JOIN product_properties pp ON pp.sku = p.sku
  WHERE f.brand = 'Leifheit' AND f.series = 'Fresh Profi' AND f.model = 'NBC-KFA'
  GROUP BY p.sku
  HAVING SUM(CASE WHEN pp.key = 'cleaning_type' AND pp.value_text = 'mop system' THEN 1 ELSE 0 END) > 0
     AND SUM(CASE WHEN pp.key = 'pack_count' AND pp.value_text = '5 pcs' THEN 1 ELSE 0 END) > 0
)
