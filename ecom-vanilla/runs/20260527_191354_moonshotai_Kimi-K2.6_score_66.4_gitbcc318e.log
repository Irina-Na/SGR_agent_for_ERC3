  tool='exec' path='/bin/sql' args=[] stdin="WITH target_skus AS (\n  SELECT sku FROM products WHERE brand = 'Einhell' AND model = 'TE 38K-KSW'\n  INTERSECT\n  SELECT sku FROM product_properties WHERE key = 'machine_type' AND value_text = 'compressor'\n  INTERSECT\n  SELECT sku FROM product_properties WHERE key = 'voltage_v' AND value_number = 230\n  INTERSECT\n  SELECT sku FROM product_properties WHERE key = 'power_w' AND value_number = 1100\n  INTERSECT\n  SELECT sku FROM product_properties WHERE key = 'tank_volume_l' AND value_number = 50\n\n  UNION\n\n  SELECT sku FROM products WHERE brand = 'Helly Hansen' AND model = 'Chelsea 2SG-Q9G'\n  INTERSECT\n  SELECT sku FROM product_properties WHERE key = 'color_family' AND value_text = 'Green'\n  INTERSECT\n  SELECT sku FROM product_properties WHERE key = 'size' AND value_text = '3XL'\n\n  UNION\n\n  SELECT sku FROM products WHERE brand = 'Black+Decker' AND model = 'KA 1D0-UK7'\n  INTERSECT\n  SELECT sku FROM product_properties WHERE key = 'tool_type' AND value_text = 'jigsaw'\n  INTERSECT\n  SELECT sku FROM product_properties WHERE key = 'voltage_v' AND value_number = 18\n\n  UNION\n\n  SELECT sku FROM products WHERE brand = 'Wurth' AND model = '313-QE4'\n  INTERSECT\n  SELECT sku FROM product_properties WHERE key = 'screw_type' AND value_text = 'wood screw'\n  INTERSECT\n  SELECT sku FROM product_properties WHERE key = 'diameter_mm' AND value_number = 5\n\n  UNION\n\n  SELECT sku FROM products WHERE brand = 'Portwest' AND model = 'KX 21D-8FE'\n  INTERSECT\n  SELECT sku FROM product_properties WHERE key = 'size' AND value_text = 'L'\n  INTERSECT\n  SELECT sku FROM product_properties WHERE key = 'color_family' AND value_text = 'Black'\n\n  UNION\n\n  SELECT sku FROM products WHERE brand = 'Proxxon' AND model = 'TB 2UD-3TX'\n  INTERSECT\n  SELECT sku FROM product_properties WHERE key = 'machine_type' AND value_text = 'bench grinder'\n  INTERSECT\n  SELECT sku FROM product_properties WHERE key = 'voltage_v' AND value_number = 230\n  INTERSECT\n  SELECT sku FROM product_properties WHERE key = 'power_w' AND value_number = 500\n)\nSELECT ts.sku, p.name, i.available_today\nFROM target_skus ts\nJOIN products p ON ts.sku = p.sku\nLEFT JOIN inventory i ON i.sku = ts.sku AND i.store_id = 'store_graz_lend';"
[32mOUT[0m: /bin/sql <<'SQL'
WITH target_skus AS (
  SELECT sku FROM products WHERE brand = 'Einhell' AND model = 'TE 38K-KSW'
  INTERSECT
  SELECT sku FROM product_properties WHERE key = 'machine_type' AND value_text = 'compressor'
  INTERSECT
  SELECT sku FROM product_properties WHERE key = 'voltage_v' AND value_number = 230
  INTERSECT
  SELECT sku FROM product_properties WHERE key = 'power_w' AND value_number = 1100
  INTERSECT
  SELECT sku FROM product_properties WHERE key = 'tank_volume_l' AND value_number = 50

  UNION

  SELECT sku FROM products WHERE brand = 'Helly Hansen' AND model = 'Chelsea 2SG-Q9G'
  INTERSECT
  SELECT sku FROM product_properties WHERE key = 'color_family' AND value_text = 'Green'
  INTERSECT
  SELECT sku FROM product_properties WHERE key = 'size' AND value_text = '3XL'

  UNION

  SELECT sku FROM products WHERE brand = 'Black+Decker' AND model = 'KA 1D0-UK7'
  INTERSECT
  SELECT sku FROM product_properties WHERE key = 'tool_type' AND value_text = 'jigsaw'
  INTERSECT
  SELECT sku FROM product_properties WHERE key = 'voltage_v' AND value_number = 18

  UNION

  SELECT sku FROM products WHERE brand = 'Wurth' AND model = '313-QE4'
  INTERSECT
  SELECT sku FROM product_properties WHERE key = 'screw_type' AND value_text = 'wood screw'
  INTERSECT
  SELECT sku FROM product_properties WHERE key = 'diameter_mm' AND value_number = 5

  UNION

  SELECT sku FROM products WHERE brand = 'Portwest' AND model = 'KX 21D-8FE'
  INTERSECT
  SELECT sku FROM product_properties WHERE key = 'size' AND value_text = 'L'
  INTERSECT
  SELECT sku FROM product_properties WHERE key = 'color_family' AND value_text = 'Black'

  UNION

  SELECT sku FROM products WHERE brand = 'Proxxon' AND model = 'TB 2UD-3TX'
  INTERSECT
  SELECT sku FROM product_properties WHERE key = 'machine_type' AND value_text = 'bench grinder'
  INTERSECT
  SELECT sku FROM product_properties WHERE key = 'voltage_v' AND value_number = 230
  INTERSECT
  SELECT sku FROM product_properties WHERE key = 'power_w' AND value_number = 500
)
SELECT ts.sku, p.name, i.available_today
FROM target_skus ts
JOIN products p ON ts.sku = p.sku
LEFT JOIN inventory i ON i.sku = ts.sku AND i.store_id = 'store_graz_lend';
SQL
sku,name,available_today
