orage_type,\n    MAX(CASE WHEN pp.key = 'wattage' THEN pp.value_text END) as wattage,\n    MAX(CASE WHEN pp.key = 'luminous_flux' THEN pp.value_text END) as luminous_flux,\n    MAX(CASE WHEN pp.key = 'sealant_type' THEN pp.value_text END) as sealant_type,\n    MAX(CASE WHEN pp.key = 'color_family' THEN pp.value_text END) as color_family,\n    MAX(CASE WHEN pp.key = 'volume' THEN pp.value_text END) as volume,\n    MAX(CASE WHEN pp.key = 'product_type' THEN pp.value_text END) as product_type\n  FROM target_products tp\n  JOIN product_properties pp ON tp.sku = pp.sku\n  GROUP BY tp.sku, tp.target_id, tp.brand, tp.series, tp.name\n),\nmatched_products AS (\n  SELECT pwp.sku\n  FROM product_with_props pwp\n  WHERE (pwp.target_id = 1 AND pwp.length = '500 mm')\n     OR (pwp.target_id = 2 AND pwp.power_source = 'petrol')\n     OR (pwp.target_id = 3 AND pwp.storage_type = 'storage bin')\n     OR (pwp.target_id = 4 AND pwp.wattage = '10 W' AND pwp.luminous_flux = '470 lm')\n     OR (pwp.target_id = 5 AND pwp.sealant_type = 'hybrid sealant' AND pwp.color_family = 'Gray' AND pwp.volume = '300 ml')\n     OR (pwp.target_id = 6 AND pwp.product_type = 'metal paint' AND pwp.color_family = 'Green')\n)\nSELECT COUNT(*) as available_count\nFROM matched_products mp\nJOIN inventory i ON mp.sku = i.sku\nWHERE i.store_id = 'store_brno_veveri' AND i.available_today >= 4;"
