WITH target_products AS (
  SELECT p.sku, p.brand, p.series, p.name,
    CASE 
      WHEN p.brand = 'Sonax' AND p.series = 'Sonax Premium Gloss 304-ZK0 Wiper Blade' AND p.name = 'Wiper Blade' THEN 1
      WHEN p.brand = 'Fiskars' AND p.series = 'Fiskars Battery X 1CD-A3X Chainsaw' AND p.name = 'Chainsaw' THEN 2
      WHEN p.brand = 'Keter' AND p.series = 'Keter Deep Stack 2OO-VJU Storage Bin and Organizer' AND p.name = 'Storage Bin and Organizer' THEN 3
      WHEN p.brand = 'Philips' AND p.series = 'Philips Professional Hue 3JS-MSN LED Bulb' AND p.name = 'LED Bulb' THEN 4
      WHEN p.brand = 'Sika' AND p.series = 'Sika Professional Sika 28T-UV8 Sealant' AND p.name = 'Sealant' THEN 5
      WHEN p.brand = 'Helios' AND p.series = 'Helios Professional Helios 29A-FTE Metal and Concrete Paint' AND p.name = 'Metal and Concrete Paint' THEN 6
      ELSE 0
    END as target_id
  FROM products p
  WHERE (p.brand = 'Sonax' AND p.series = 'Sonax Premium Gloss 304-ZK0 Wiper Blade' AND p.name = 'Wiper Blade')
     OR (p.brand = 'Fiskars' AND p.series = 'Fiskars Battery X 1CD-A3X Chainsaw' AND p.name = 'Chainsaw')
     OR (p.brand = 'Keter' AND p.series = 'Keter Deep Stack 2OO-VJU Storage Bin and Organizer' AND p.name = 'Storage Bin and Organizer')
     OR (p.brand = 'Philips' AND p.series = 'Philips Professional Hue 3JS-MSN LED Bulb' AND p.name = 'LED Bulb')
     OR (p.brand = 'Sika' AND p.series = 'Sika Professional Sika 28T-UV8 Sealant' AND p.name = 'Sealant')
     OR (p.brand = 'Helios' AND p.series = 'Helios Professional Helios 29A-FTE Metal and Concrete Paint' AND p.name = 'Metal and Concrete Paint')
),
product_with_props AS (
  SELECT tp.sku, tp.target_id, tp.brand, tp.series, tp.name,
    MAX(CASE WHEN pp.key = 'length' THEN pp.value_text END) as length,
    MAX(CASE WHEN pp.key = 'power_source' THEN pp.value_text END) as power_source,
    MAX(CASE WHEN pp.key = 'storage_type' THEN pp.value_text END) as storage_type,
    MAX(CASE WHEN pp.key = 'wattage' THEN pp.value_text END) as wattage,
    MAX(CASE WHEN pp.key = 'luminous_flux' THEN pp.value_text END) as luminous_flux,
    MAX(CASE WHEN pp.key = 'sealant_type' THEN pp.value_text END) as sealant_type,
    MAX(CASE WHEN pp.key = 'color_family' THEN pp.value_text END) as color_family,
    MAX(CASE WHEN pp.key = 'volume' THEN pp.value_text END) as volume,
    MAX(CASE WHEN pp.key = 'product_type' THEN pp.value_text END) as product_type
  FROM target_products tp
  JOIN product_properties pp ON tp.sku = pp.sku
  GROUP BY tp.sku, tp.target_id, tp.brand, tp.series, tp.name
),
matched_products AS (
  SELECT pwp.sku
  FROM product_with_props pwp
  WHERE (pwp.target_id = 1 AND pwp.length = '500 mm')
     OR (pwp.target_id = 2 AND pwp.power_source = 'petrol')
     OR (pwp.target_id = 3 AND pwp.storage_type = 'storage bin')
     OR (pwp.target_id = 4 AND pwp.wattage = '10 W' AND pwp.luminous_flux = '470 lm')
     OR (pwp.target_id = 5 AND pwp.sealant_type = 'hybrid sealant' AND pwp.color_family = 'Gray' AND pwp.volume = '300 ml')
     OR (pwp.target_id = 6 AND pwp.product_type = 'metal paint' AND pwp.color_family = 'Green')
)
SELECT COUNT(*) as available_count
FROM matched_products mp
JOIN inventory i ON mp.sku = i.sku
WHERE i.store_id = 'store_brno_veveri' AND i.available_today >= 4;
